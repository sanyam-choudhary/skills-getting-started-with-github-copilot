  "version": "0.2.0",
  "configurations": [
        # Create and switch to the new branch
    git checkout -b accelerate-with-copilot
    
    # Push the branch to remote (and set it to track the remote branch)
    git push -u origin accelerate-with-copilot
    {
      "name": "Launch Mergington WebApp",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "src.app:app",
        "--reload",
        "--reload-include",
        "src/static/*"
      ],
      "jinja": true
    }
  ]
}
